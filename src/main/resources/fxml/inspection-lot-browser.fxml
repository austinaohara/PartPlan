<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@../styles/main.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.InspectionLotBrowserController">
    <top>
        <VBox spacing="12.0" styleClass="top-bar">
            <padding>
                <Insets bottom="18.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label styleClass="screen-title" text="Inspection Lots" />
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#onRefreshData" styleClass="secondary-button" text="Refresh" />
                <Button mnemonicParsing="false" onAction="#onReturnToHub" styleClass="secondary-button" text="Return to Hub" />
            </HBox>
            <Label styleClass="browser-copy" text="Open an existing inspection lot or create a new lot from a saved inspection plan." wrapText="true" />
        </VBox>
    </top>

    <center>
        <HBox spacing="24.0" styleClass="browser-shell">
            <padding>
                <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
            </padding>

            <VBox spacing="16.0" styleClass="editor-card" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                </padding>
                <HBox alignment="CENTER_LEFT" spacing="12.0">
                    <Label styleClass="panel-title" text="Existing Lots" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="savedLotCountLabel" styleClass="browser-stat" text="0 saved lots" />
                </HBox>
                <Label styleClass="editor-copy" text="Scroll through saved inspection lots and reopen any lot to continue entering part data." wrapText="true" />
                <TableView fx:id="savedLotsTableView" styleClass="browser-table" VBox.vgrow="ALWAYS">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="lotNameColumn" prefWidth="220.0" text="Lot" />
                        <TableColumn fx:id="lotPlanColumn" prefWidth="220.0" text="Plan" />
                        <TableColumn fx:id="lotSizeColumn" prefWidth="90.0" text="Size" />
                        <TableColumn fx:id="lotUpdatedColumn" prefWidth="180.0" text="Updated" />
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Button fx:id="openLotButton" mnemonicParsing="false" onAction="#onOpenLot" styleClass="primary-button" text="Open Selected Lot" />
                </HBox>
            </VBox>

            <VBox maxWidth="340.0" prefWidth="340.0" spacing="16.0" styleClass="editor-card">
                <padding>
                    <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                </padding>
                <Label styleClass="panel-title" text="Create New Lot" />
                <Label styleClass="editor-copy" text="Choose a saved inspection plan, set the lot name and lot size, then open the new lot in the part editor." wrapText="true" />
                <Label styleClass="field-label" text="Saved Plan" />
                <ComboBox fx:id="planSelectorComboBox" prefWidth="292.0" promptText="Select saved plan" />
                <Label styleClass="field-label" text="Lot Name" />
                <TextField fx:id="lotNameField" prefWidth="292.0" promptText="Inspection lot name" />
                <Label styleClass="field-label" text="Lot Size" />
                <Spinner fx:id="lotSizeSpinner" prefWidth="140.0" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="createLotButton" maxWidth="Infinity" mnemonicParsing="false" onAction="#onCreateLot" styleClass="primary-button" text="Create and Open Lot" />
            </VBox>
        </HBox>
    </center>
</BorderPane>

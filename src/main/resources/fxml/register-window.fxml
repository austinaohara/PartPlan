<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<AnchorPane focusTraversable="true" nodeOrientation="LEFT_TO_RIGHT" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.RegisterController">
   <children>
      <VBox alignment="CENTER" maxHeight="260.0" maxWidth="380.0" minHeight="260.0" minWidth="380.0" prefHeight="260.0" prefWidth="380.0" spacing="12.0">
         <children>
            <Label text="Create an account and company." />
            <GridPane alignment="CENTER" hgap="8.0" prefHeight="112.0" prefWidth="330.0" vgap="8.0">
              <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" maxWidth="130.0" minWidth="10.0" prefWidth="96.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="230.0" minWidth="10.0" prefWidth="220.0" />
              </columnConstraints>
              <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
              </rowConstraints>
               <children>
                  <Label text="E-Mail" />
                  <Label text="Password" GridPane.rowIndex="1" />
                  <Label text="Company" GridPane.rowIndex="2" />
                  <TextField fx:id="emailTextField" GridPane.columnIndex="1" />
                  <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <TextField fx:id="companyTextField" promptText="Company name" GridPane.columnIndex="1" GridPane.rowIndex="2" />
               </children>
            </GridPane>
            <Button fx:id="registerButton" mnemonicParsing="false" onAction="#onRegisterPressed" text="Register" />
            <Label fx:id="errorLabel" text="Label" textFill="RED" visible="false" wrapText="true" />
         </children>
      </VBox>
   </children>
</AnchorPane>

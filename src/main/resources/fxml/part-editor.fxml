<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1100.0" stylesheets="@../styles/main.css" xmlns="http://javafx.com/javafx/20.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.PartEditorController">
    <top>
        <VBox spacing="14.0" styleClass="top-bar">
            <padding>
                <Insets bottom="18.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="screen-title" text="Part Editor" />
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label styleClass="field-label" text="Plan" />
                <ComboBox fx:id="planSelectorComboBox" prefWidth="260.0" promptText="Select saved plan" />
                <Label styleClass="field-label" text="Lot Name" />
                <TextField fx:id="lotNameField" onAction="#onLotNameCommitted" prefWidth="220.0" promptText="Inspection lot name" />
                <Label styleClass="field-label" text="Lot Size" />
                <Spinner fx:id="lotSizeSpinner" prefWidth="110.0" />
                <Button fx:id="createLotButton" mnemonicParsing="false" onAction="#onCreateLot" styleClass="primary-button" text="New Lot" />
                <Region HBox.hgrow="ALWAYS" />
                <Label styleClass="field-label" text="Inspection Lots" />
                <ComboBox fx:id="savedLotsComboBox" prefWidth="280.0" promptText="Open saved inspection lot" />
                <Button fx:id="openLotButton" mnemonicParsing="false" onAction="#onOpenLot" styleClass="secondary-button" text="Open Lot" />
                <Button mnemonicParsing="false" onAction="#onRefreshData" styleClass="secondary-button" text="Refresh" />
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Label styleClass="field-label" text="Loaded Lot" />
                <Label fx:id="loadedLotLabel" styleClass="toolbar-pill" text="" />
                <Label styleClass="field-label" text="Loaded Plan" />
                <Label fx:id="loadedPlanLabel" styleClass="toolbar-pill" text="No plan selected" />
                <Label styleClass="field-label" text="Summary" />
                <Label fx:id="lotSummaryLabel" styleClass="toolbar-pill" text="No inspection lot selected" />
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane fx:id="editorTabPane" styleClass="editor-tabs" tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <Tab text="Part View">
                    <BorderPane>
                        <top>
                            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="editor-toolbar">
                                <padding>
                                    <Insets bottom="0.0" left="24.0" right="24.0" top="24.0" />
                                </padding>
                                <Label styleClass="field-label" text="Current Part" />
                                <Button fx:id="previousPartButton" mnemonicParsing="false" onAction="#onPreviousPart" styleClass="secondary-button" text="Previous" />
                                <ComboBox fx:id="partSelectorComboBox" prefWidth="170.0" />
                                <Button fx:id="nextPartButton" mnemonicParsing="false" onAction="#onNextPart" styleClass="secondary-button" text="Next" />
                            </HBox>
                        </top>
                        <center>
                            <VBox spacing="14.0" styleClass="editor-card">
                                <padding>
                                    <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                                </padding>
                                <Label fx:id="currentPartTitleLabel" styleClass="panel-title" text="Measurements for Part 1 of 1" />
                                <Label styleClass="editor-copy" text="Bubbles come from the lot&apos;s saved plan snapshot. Enter measurement values for the current part and they will be saved automatically." wrapText="true" />
                                <TableView fx:id="partTableView" editable="true" VBox.vgrow="ALWAYS">
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                    <columns>
                                        <TableColumn fx:id="partSequenceColumn" editable="false" prefWidth="80.0" text="#" />
                                        <TableColumn fx:id="partBubbleNameColumn" editable="false" prefWidth="220.0" text="Bubble" />
                                        <TableColumn fx:id="partNominalColumn" editable="false" prefWidth="90.0" text="Nom" />
                                        <TableColumn fx:id="partLowerToleranceColumn" editable="false" prefWidth="85.0" text="-Tol" />
                                        <TableColumn fx:id="partUpperToleranceColumn" editable="false" prefWidth="85.0" text="+Tol" />
                                        <TableColumn fx:id="partNoteColumn" editable="false" prefWidth="190.0" text="Note" />
                                        <TableColumn fx:id="partMeasurementColumn" prefWidth="130.0" text="Measurement" />
                                    </columns>
                                </TableView>
                            </VBox>
                        </center>
                    </BorderPane>
                </Tab>

                <Tab text="Master View">
                    <VBox spacing="14.0" styleClass="editor-card">
                        <padding>
                            <Insets bottom="24.0" left="24.0" right="24.0" top="24.0" />
                        </padding>
                        <Label styleClass="panel-title" text="Lot Overview" />
                        <Label styleClass="editor-copy" text="Review the saved inspection lot with parts down the rows and plan bubbles across the columns." wrapText="true" />
                        <TableView fx:id="masterTableView" editable="false" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.Group?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<BorderPane fx:id="root" focusTraversable="true" prefHeight="700.0" prefWidth="1100.0" stylesheets="@../styles/main.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.PlanEditorController">
    <top>
        <VBox spacing="14.0" styleClass="top-bar">
            <padding>
                <Insets bottom="18.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label styleClass="screen-title" text="Plan Editor" />
            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <Button mnemonicParsing="false" onAction="#onNewPlan" styleClass="secondary-button" text="New Plan" />
                <Button mnemonicParsing="false" onAction="#onSavePlan" styleClass="primary-button" text="Save Plan" />
                <Button mnemonicParsing="false" onAction="#onOpenPlan" styleClass="secondary-button" text="Open Plan" />
                <Button mnemonicParsing="false" onAction="#onDeletePlan" styleClass="secondary-button" text="Delete Plan" />
                <Button mnemonicParsing="false" onAction="#onImportDrawing" styleClass="primary-button" text="Add Page" />
                <Separator orientation="VERTICAL" prefHeight="28.0" />
                <Label styleClass="field-label" text="Plan Name" />
                <TextField fx:id="planNameField" onAction="#onPlanNameChanged" onKeyReleased="#onPlanNameChanged" prefWidth="280.0" promptText="Inspection plan name" />
            <Button mnemonicParsing="false" onAction="#OnOpenDataEditor" styleClass="secondary-button" text="Open in Data Editor" />
            </HBox>
        </VBox>
    </top>

    <left>
        <HBox>
            <!-- Expanded left panel -->
            <VBox fx:id="leftPanel" prefWidth="280.0" styleClass="tool-window">
                <!-- Title bar: title on left, X on right -->
                <HBox alignment="CENTER_LEFT" styleClass="tool-window-header">
                    <Label styleClass="tool-window-title" text="Saved Plans" HBox.hgrow="ALWAYS" />
                    <HBox HBox.hgrow="ALWAYS" />
                    <Button onAction="#onToggleLeftPanel" styleClass="tool-window-close-btn" text="X" />
                </HBox>
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="12.0" />
                    </padding>
                    <ListView fx:id="savedPlansListView" prefHeight="280.0" styleClass="saved-plans-list" />
                    <Separator />
                    <Label styleClass="tool-window-section-title" text="Current Plan" />
                    <Label styleClass="field-label" text="Pages" />
                    <ListView fx:id="planPagesListView" prefHeight="150.0" styleClass="saved-plans-list" />
                    <Label styleClass="field-label" text="Drawing File" />
                    <Label fx:id="drawingFileNameLabel" styleClass="field-value" text="No drawing selected" wrapText="true" />
                    <Label styleClass="field-label" text="Drawing Path" />
                    <Label fx:id="drawingPathLabel" styleClass="field-value" text="" wrapText="true" />
                </VBox>
            </VBox>

            <!-- Resize handle (right edge of left panel) -->
            <VBox fx:id="leftResizeHandle" prefWidth="5.0" styleClass="resize-handle-v" />

            <!-- Collapsed left strip -->
            <VBox fx:id="leftCollapsedTab" alignment="TOP_CENTER" managed="false" onMouseClicked="#onToggleLeftPanel" prefWidth="28.0" styleClass="tool-strip" visible="false">
                <Group>
                    <Label rotate="-90" styleClass="tool-strip-label" text="Saved Plans" />
                </Group>
            </VBox>
        </HBox>
    </left>

    <center>
        <StackPane styleClass="canvas-shell">
            <Label fx:id="emptyStateLabel" styleClass="empty-state" text="Add a drawing page to start this inspection plan." wrapText="true" />
            <Label fx:id="pdfPreviewLabel" managed="false" styleClass="empty-state" text="PDF selected. The file is saved with the plan, but PDF preview is not available in this editor." visible="false" wrapText="true" />
            <ScrollPane fx:id="drawingScrollPane" fitToHeight="false" fitToWidth="false" pannable="true" styleClass="drawing-scroll-pane">
                <content>
                    <Group>
                        <ImageView fx:id="drawingImageView" preserveRatio="true" smooth="true" />
                        <Pane fx:id="bubbleOverlayPane" pickOnBounds="true" />
                    </Group>
                </content>
            </ScrollPane>
        </StackPane>
    </center>

    <right>
        <HBox>
            <!-- Collapsed right strip -->
            <VBox fx:id="rightCollapsedTab" alignment="TOP_CENTER" managed="false" onMouseClicked="#onToggleRightPanel" prefWidth="28.0" styleClass="tool-strip" visible="false">
                <Group>
                    <Label rotate="90" styleClass="tool-strip-label" text="Bubble Data" />
                </Group>
            </VBox>

            <!-- Resize handle (left edge of right panel) -->
            <VBox fx:id="rightResizeHandle" prefWidth="5.0" styleClass="resize-handle-v" />

            <!-- Expanded right panel -->
            <VBox fx:id="rightPanel" prefWidth="280.0" styleClass="tool-window">
                <HBox styleClass="tool-window-header" alignment="CENTER_LEFT">
                    <Button onAction="#onToggleRightPanel" styleClass="tool-window-close-btn" text="X" />
                    <Label text="Bubble Data" styleClass="tool-window-title" HBox.hgrow="ALWAYS" />
                </HBox>
                <VBox spacing="10.0" VBox.vgrow="ALWAYS">
                    <padding>
                        <Insets bottom="16.0" left="16.0" right="16.0" top="12.0" />
                    </padding>
                    <Label styleClass="field-label" text="Selected Bubble" />
                    <Label fx:id="selectedBubbleLabel" styleClass="bubble-selected-label" text="No bubble selected" wrapText="true" />
                    <Label fx:id="bubbleHintLabel" styleClass="field-value" text="Shift + Click on the drawing to place a bubble." wrapText="true" />
                    <Separator />
                    <Label styleClass="field-label" text="Characteristic" />
                    <TextField fx:id="characteristicField" promptText="Enter characteristic" />
                    <Label styleClass="field-label" text="Inspection Type" />
                    <ComboBox fx:id="inspectionTypeComboBox" />
                    <Label styleClass="field-label" text="Nominal Value" />
                    <TextField fx:id="nominalValueField" promptText="Optional numeric value" />
                    <Label styleClass="field-label" text="Lower Tolerance" />
                    <TextField fx:id="lowerToleranceField" promptText="Optional numeric value" />
                    <Label styleClass="field-label" text="Upper Tolerance" />
                    <TextField fx:id="upperToleranceField" promptText="Optional numeric value" />
                    <Label styleClass="field-label" text="Notes" />
                    <TextArea fx:id="bubbleNoteArea" prefRowCount="6" promptText="Enter notes for this bubble" wrapText="true" />
                    <Button fx:id="saveBubbleButton" mnemonicParsing="false" onAction="#onSaveBubble" styleClass="primary-button" text="Save Bubble" />
                </VBox>
            </VBox>
        </HBox>
    </right>
</BorderPane>
